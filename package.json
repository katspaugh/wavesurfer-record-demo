{
  "name": "wavesurfer-record-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "css-types": "tcm -p 'src/**/*.module.css' .",
    "css-types:check": "tcm -p 'src/**/*.module.css' . -l",
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "yarn css-types:check && tsc && vite build",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "vitest run",
    "typecheck": "yarn css-types:check && tsc --noEmit"
  },
  "dependencies": {
    "@mediabunny/mp3-encoder": "^1.40.1",
    "mediabunny": "^1.40.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "wavesurfer.js": "^7.11.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.4.0",
    "happy-dom": "^20.9.0",
    "typed-css-modules": "^0.9.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
